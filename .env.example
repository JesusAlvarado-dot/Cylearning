# CyLearn Flutter — variables de entorno
# Copia este archivo a .env y ajusta los valores.

# URL base del API (en producción, el dominio del backend desplegado)
API_URL=http://localhost:3000/api

# URL pública de la web desplegada, usada para armar los links de
# invitación de organizaciones (/#/unirse?codigo=X).
APP_URL=https://cylearn-web.onrender.com

# App
APP_NAME=CyLearn
VERSION=1.0.0
DEBUG=false

# Timeout de las llamadas HTTP en segundos
API_TIMEOUT=30

# Google Sign-In — client ID del cliente OAuth "Web" (Google Cloud Console).
GOOGLE_CLIENT_ID_WEB=
