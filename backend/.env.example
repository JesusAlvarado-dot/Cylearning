# ═══════════════════════════════════════════════════════════════
# CyLearn Backend — variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real a git (ya está en .gitignore).
# ═══════════════════════════════════════════════════════════════

# ── Base de datos ────────────────────────────────────────────────
# URI de MongoDB (local o Atlas). En producción usa un usuario de
# base de datos con permisos mínimos y rota la contraseña si se filtra.
MONGODB_URI=mongodb://localhost:27017/app-escuela
MONGODB_TEST_URI=mongodb://localhost:27017/app-escuela-test

# ── JWT ──────────────────────────────────────────────────────────
# OBLIGATORIO en producción (el servidor no arranca sin él).
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=7d

# ── Servidor ─────────────────────────────────────────────────────
PORT=3000
# En producción: NODE_ENV=production (oculta detalles de errores 500)
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────
# En desarrollo '*' está bien; en producción pon el dominio real de la app:
# CORS_ORIGIN=https://tu-dominio.com
CORS_ORIGIN=*

# ── Proxy ────────────────────────────────────────────────────────
# Ponlo en true SOLO si el backend corre detrás de un proxy/CDN
# (nginx, Render, Railway...) para que el rate limiting vea IPs reales.
TRUST_PROXY=false

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
