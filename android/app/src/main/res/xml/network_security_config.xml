<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 9+ bloquea HTTP sin cifrar por defecto. El backend de desarrollo
  corre en la PC sin HTTPS, así que se permite cleartext SOLO hacia las
  direcciones de desarrollo:
    - 10.0.2.2: alias del localhost de la PC visto desde el emulador
    - 127.0.0.1 / localhost: para `adb reverse` con dispositivo físico
  Cualquier backend desplegado en producción debe usar HTTPS (no requiere
  cambios aquí: el bloqueo de cleartext solo aplica a HTTP plano).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
